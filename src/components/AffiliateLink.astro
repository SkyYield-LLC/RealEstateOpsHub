---
import { getAffiliate } from '../data/affiliates';

interface Props {
  /** Slug from src/data/affiliates.ts */
  slug: string;
  /** Optional override for the visible link text. Defaults to the affiliate name. */
  label?: string;
  /** Render as a button (CTA) instead of inline link. */
  cta?: boolean;
  class?: string;
}

const { slug, label, cta = false, class: className = '' } = Astro.props;
const affiliate = getAffiliate(slug);

// Soft-fail: if the slug isn't in affiliates.json, still render a link.
// The /recommends/<slug> URL will 404 at runtime but the build succeeds
// and the visual presentation renders correctly. This is UX debt to fix
// (add the affiliate, or update the retrofit), not a build failure.
if (!affiliate) {
  console.warn(`[AffiliateLink] unknown slug "${slug}" — falling back to plain redirect`);
}

const href = `/recommends/${slug}`;
const text = label ?? affiliate?.name ?? slug;
const classes = cta ? `affiliate-cta ${className}` : `affiliate-link ${className}`;
---
<a
  href={href}
  class={classes}
  rel="sponsored nofollow noopener"
  target="_blank"
  data-affiliate={slug}
>
  {cta ? <>{text} →</> : text}<slot />
</a>
