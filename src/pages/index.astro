---
import Base from '../layouts/Base.astro';
import NewsletterSignup from '../components/NewsletterSignup.astro';
import { site } from '../config/site';

const featuredSections = [
  {
    no: '01',
    tag: 'Property Management',
    title: 'Buildium 2026 — Field Review',
    excerpt: 'Buildium remains the workhorse for portfolios from 50 to 1,000 doors. Our team breaks down where the platform earns its rent — and the two friction points operators absorb.',
    href: '/reviews/buildium-review-2026',
    readTime: '14 min',
  },
  {
    no: '02',
    tag: 'Lead Engine',
    title: 'Carrot for Investor Lead Generation',
    excerpt: 'Carrot owns the investor SEO market for a reason. The template library is deep; the long-term SEO economics still depend on what operators do with the platform.',
    href: '/reviews/carrot-review-2026',
    readTime: '11 min',
  },
  {
    no: '03',
    tag: 'Guide',
    title: 'The Real Estate Ops Tech Stack',
    excerpt: 'Seven specifications — leads, CRM, transaction, PMS, accounting, marketing, comms — and the specific platforms our team specs for brokerages crossing 25 agents.',
    href: '/guides/best-real-estate-tech-stack-2026',
    readTime: '13 min',
  },
];

const specifications = [
  {
    no: '01',
    title: 'Operator perspective',
    body: 'Every section is specified by a team that has actually deployed the platform across portfolios, agents, and ops staff — not by reviewers reading vendor decks.',
  },
  {
    no: '02',
    title: 'Door-count aware',
    body: 'Tools that work for a single brokerage break at five. We measure exactly where each system requires a platform change, an integration shim, or an absorbed cost.',
  },
  {
    no: '03',
    title: 'Transparent cost basis',
    body: 'Per-door fees, agent seat costs, MLS-feed surcharges, payment processing markup — surfaced explicitly so the proposal stops being a surprise at signature.',
  },
];
---
<Base title={site.name} description={site.description}>

  <!-- HERO — blueprint cover -->
  <section class="hero">
    <div class="hero-grid-overlay"></div>
    <div class="hero-inner container">
      <div class="hero-content">
        <div class="hero-badge" style="font-family:'Outfit',sans-serif; letter-spacing:0.18em; text-transform:uppercase; font-size:0.72rem;">
          Specified by brokerage operators
        </div>
        <h1 style="font-family:'Instrument Serif',Georgia,serif;">The blueprint of software <em>that runs the brokerage</em></h1>
        <p class="hero-sub">
          Independent reviews of property management, lead generation, transaction, and back-office
          platforms — written by operators who close, manage, and account for the doors.
        </p>
        <div class="hero-actions">
          <a href="/reviews" class="btn btn-teal btn-lg">Open the Blueprint →</a>
          <a href="/guides/best-real-estate-tech-stack-2026" class="btn btn-outline btn-lg" style="color:#FFFFFF; border-color:rgba(255,255,255,.6); background:rgba(255,255,255,.08);">The Tech Stack</a>
        </div>
      </div>

      <div class="hero-stat-card">
        <div class="hero-stats">
          <div class="stat-item">
            <span class="stat-number">7<em>+</em></span>
            <span class="stat-label">Platforms specified</span>
          </div>
          <div class="stat-divider"></div>
          <div class="stat-item">
            <span class="stat-number">Brokerage</span>
            <span class="stat-label">Operator focus</span>
          </div>
          <div class="stat-divider"></div>
          <div class="stat-item">
            <span class="stat-number">Independent</span>
            <span class="stat-label">Editorial standard</span>
          </div>
          <div class="stat-divider"></div>
          <div class="stat-item">
            <span class="stat-number">2026</span>
            <span class="stat-label">Blueprint edition</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- FEATURED SECTIONS -->
  <section class="section">
    <div class="container">
      <div class="section-head">
        <p class="section-label">Featured Sections</p>
        <h2 class="section-title">This edition's specified picks</h2>
        <p class="section-sub" style="font-family:'Instrument Serif',Georgia,serif; font-style:italic; opacity:0.78; max-width:42rem; margin-top:0.75rem;">
          Three platforms reviewed in depth — tested against the realities of multi-door portfolios and multi-agent brokerages.
        </p>
      </div>

      <div class="card-grid">
        {featuredSections.map(s => (
          <a href={s.href} class="post-card">
            <div class="post-card-body">
              <div style="display:flex; align-items:baseline; gap:0.85rem; margin-bottom:0.6rem;">
                <span style="font-family:'Outfit',sans-serif; color:#c9a84c; font-size:0.7rem; letter-spacing:0.2em; text-transform:uppercase; font-weight:600;">Section {s.no}</span>
                <span class="post-card-tag">{s.tag}</span>
              </div>
              <h3 style="font-family:'Instrument Serif',Georgia,serif;">{s.title}</h3>
              <p>{s.excerpt}</p>
              <div class="post-card-meta">
                <span style="font-style:italic;">Reading time</span>
                <span>·</span>
                <span>{s.readTime}</span>
              </div>
            </div>
          </a>
        ))}
      </div>

      <div style="text-align:center; margin-top:2.5rem;">
        <a href="/reviews" class="btn btn-outline">View Full Blueprint →</a>
      </div>
    </div>
  </section>

  <!-- SPECIFICATIONS -->
  <section class="section section-alt">
    <div class="container">
      <div class="section-head">
        <p class="section-label">Specifications</p>
        <h2 class="section-title">How {site.name} is specified</h2>
      </div>

      <div class="feature-grid">
        {specifications.map(spec => (
          <div class="feature-item">
            <div style="font-family:'Outfit',sans-serif; color:#c9a84c; font-size:0.8rem; letter-spacing:0.2em; margin-bottom:0.6rem; font-weight:600;">SPEC {spec.no}</div>
            <h3 style="font-family:'Instrument Serif',Georgia,serif;">{spec.title}</h3>
            <p>{spec.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- NEWSLETTER -->
  <section class="container" style="padding:clamp(1.5rem,4vw,2rem) clamp(1rem,4vw,1.5rem) clamp(2.5rem,6vw,4rem);">
    <NewsletterSignup
      variant="hero"
      title={`The ${site.name} field notes`}
      description="One weekly dispatch — new sections added to the blueprint, with operator notes. No spam."
      ctaLabel="Subscribe"
    />
  </section>

</Base>
